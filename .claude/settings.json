{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git blame:*)",
      "Bash(git describe:*)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git remote get-url:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git config get:*)",
      "Bash(git stash list:*)",
      "Bash(git tag --list:*)",
      "Bash(git worktree list:*)",

      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go version)",
      "Bash(go list:*)",
      "Bash(go mod download:*)",
      "Bash(go mod graph)",
      "Bash(go mod why:*)",
      "Bash(go run:*)",

      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",

      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(command -v:*)",
      "Bash(file:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(date:*)",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(true)",
      "Bash(false)"
    ]
  }
}
